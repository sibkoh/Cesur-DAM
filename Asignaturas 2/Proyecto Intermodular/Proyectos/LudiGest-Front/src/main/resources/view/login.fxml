<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.PasswordField?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<VBox alignment="CENTER" spacing="15.0" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.lexludi.front.controller.LoginController">
    <padding>
        <Insets bottom="40.0" left="40.0" right="40.0" top="40.0" />
    </padding>
    <children>
        <Label text="LudiGest - Acceso Administrador">
            <font>
                <Font name="System Bold" size="18.0" />
            </font>
            <VBox.margin>
                <Insets bottom="20.0" />
            </VBox.margin>
        </Label>
        
        <VBox spacing="5.0">
            <children>
                <Label text="Usuario:" />
                <TextField fx:id="txtUsername" promptText="Introduce tu usuario" />
            </children>
        </VBox>
        
        <VBox spacing="5.0">
            <children>
                <Label text="Contraseña:" />
                <PasswordField fx:id="txtPassword" promptText="Introduce tu contraseña" />
            </children>
        </VBox>
        
        <Button fx:id="btnEntrar" mnemonicParsing="false" onAction="#handleEntrar" prefWidth="150.0" text="Entrar" defaultButton="true">
            <VBox.margin>
                <Insets top="15.0" />
            </VBox.margin>
        </Button>
    </children>
</VBox>