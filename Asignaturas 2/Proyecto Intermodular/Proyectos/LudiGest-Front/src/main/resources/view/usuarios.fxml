<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<AnchorPane xmlns="http://javafx.com/javafx"
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="com.lexludi.front.controller.UsuariosController"
            prefHeight="650.0" prefWidth="900.0">
    <children>
        <SplitPane dividerPositions="0.4" AnchorPane.bottomAnchor="0.0" AnchorPane.leftAnchor="0.0" 
                   AnchorPane.rightAnchor="0.0" AnchorPane.topAnchor="0.0">
            <items>
                <VBox spacing="10.0" styleClass="panel-izquierdo">
                    <children>
                        <Label text="Lista de Usuarios" styleClass="label-seccion"/>
                        <TableView fx:id="tblUsuarios" VBox.vgrow="ALWAYS">
                            <columns>
                                <TableColumn fx:id="colUsername" text="Usuario" prefWidth="120.0"/>
                                <TableColumn fx:id="colRol" text="Rol" prefWidth="100.0"/>
                            </columns>
                        </TableView>
                    </children>
                    <padding>
                        <Insets bottom="10.0" left="10.0" right="10.0" top="10.0" />
                    </padding>
                </VBox>

                <ScrollPane fitToWidth="true" styleClass="scroll-transparente">
                    <content>
                        <VBox spacing="15.0" styleClass="panel-derecho">
                            <children>
                                <Label text="Nuevo Usuario" styleClass="label-seccion"/>
                                
                                <Label text="Nombre:" styleClass="label-bold"/>
                                <TextField fx:id="txtNombre" promptText="Ej: Juan"/>
                                
                                <Label text="Apellidos:" styleClass="label-bold"/>
                                <TextField fx:id="txtApellidos" promptText="Ej: Pérez García"/>
                                
                                <Label text="Apodo (Opcional):" styleClass="label-bold"/>
                                <TextField fx:id="txtApodo" promptText="Ej: Juancho"/>
                                
                                <Label text="Email:" styleClass="label-bold"/>
                                <TextField fx:id="txtEmail" promptText="ejemplo@correo.com"/>
                                
                                <Label text="Teléfono:" styleClass="label-bold"/>
                                <TextField fx:id="txtTelefono" promptText="Ej: 600123456"/>
                                
                                <Label text="Nombre de Usuario:" styleClass="label-bold"/>
                                <TextField fx:id="txtUsername" promptText="username"/>
                                
                                <Label text="Contraseña:" styleClass="label-bold"/>
                                <PasswordField fx:id="txtPassword" />
                                
                                <Label text="Rol:" styleClass="label-bold"/>
                                <ComboBox fx:id="cmbRol" prefWidth="200.0" promptText="Seleccione Rol"/>

                                <Label text="Tipo de Cuota:" styleClass="label-bold"/>
                                <ComboBox fx:id="cmbTipoCuota" prefWidth="200.0" promptText="Seleccione Cuota"/>
                                
                                <Label text="¿Tiene Llave del Local?" styleClass="label-bold"/>
                                <ComboBox fx:id="cmbTieneLlave" prefWidth="200.0" promptText="Seleccione SÍ o NO"/>
                                
                                <Button fx:id="btnGuardar" text="Guardar Usuario" onAction="#handleGuardar"
                                        styleClass="btn-accent" prefWidth="200.0"/>
                            </children>
                            <padding>
                                <Insets bottom="20.0" left="20.0" right="20.0" top="20.0" />
                            </padding>
                        </VBox>
                    </content>
                </ScrollPane>
            </items>
        </SplitPane>
    </children>
</AnchorPane>