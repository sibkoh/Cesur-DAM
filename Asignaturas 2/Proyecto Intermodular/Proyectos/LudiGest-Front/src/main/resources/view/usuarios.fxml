<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<AnchorPane xmlns="http://javafx.com/javafx"
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="com.lexludi.front.controller.UsuariosController"
            prefHeight="600.0" prefWidth="800.0">
    <children>
        <SplitPane dividerPositions="0.4" AnchorPane.bottomAnchor="0.0" AnchorPane.leftAnchor="0.0" 
                   AnchorPane.rightAnchor="0.0" AnchorPane.topAnchor="0.0">
            <items>
                <VBox spacing="10.0">
                    <children>
                        <Label text="Lista de Usuarios" style="-fx-font-size: 18px; -fx-font-weight: bold;"/>
                        <TableView fx:id="tblUsuarios" VBox.vgrow="ALWAYS">
                            <columns>
                                <TableColumn fx:id="colUsername" text="Usuario" prefWidth="100.0"/>
                                <TableColumn fx:id="colRol" text="Rol" prefWidth="100.0"/>
                            </columns>
                        </TableView>
                    </children>
                    <padding>
                        <Insets bottom="10.0" left="10.0" right="10.0" top="10.0" />
                    </padding>
                </VBox>

                <VBox spacing="15.0">
                    <children>
                        <Label text="Nuevo Usuario" style="-fx-font-size: 18px; -fx-font-weight: bold;"/>
                        
                        <Label text="Nombre Completo:"/>
                        <TextField fx:id="txtNombre" promptText="Ej: Juan Pérez"/>
                        
                        <Label text="Email:"/>
                        <TextField fx:id="txtEmail" promptText="ejemplo@correo.com"/>
                        
                        <Label text="Teléfono:"/>
                        <TextField fx:id="txtTelefono" promptText="Ej: 600123456"/>
                        <Label text="Nombre de Usuario:"/>
                        <TextField fx:id="txtUsername" promptText="username"/>
                        
                        <Label text="Contraseña:"/>
                        <PasswordField fx:id="txtPassword" />
                        
                        <Label text="Rol:"/>
                        <ComboBox fx:id="cmbRol" prefWidth="200.0" promptText="Seleccione Rol"/>
                        
                        <Button fx:id="btnGuardar" text="Guardar Usuario" onAction="#handleGuardar"
                                style="-fx-background-color: #2196F3; -fx-text-fill: white; -fx-font-weight: bold;" 
                                prefWidth="200.0"/>
                    </children>
                    <padding>
                        <Insets bottom="20.0" left="20.0" right="20.0" top="20.0" />
                    </padding>
                </VBox>
            </items>
        </SplitPane>
    </children>
</AnchorPane>