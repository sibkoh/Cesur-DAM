<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.*?>

<AnchorPane prefHeight="750.0" prefWidth="1100.0" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.lexludi.front.controller.CatalogoController">
    <children>
        <SplitPane dividerPositions="0.55" AnchorPane.bottomAnchor="0.0" AnchorPane.leftAnchor="0.0" AnchorPane.rightAnchor="0.0" AnchorPane.topAnchor="0.0">
            <items>
                
                <VBox spacing="10.0" style="-fx-background-color: #f4f4f4;">
                    <padding>
                        <Insets bottom="10.0" left="15.0" right="15.0" top="15.0" />
                    </padding>
                    <children>
                        <HBox alignment="CENTER_LEFT" spacing="15.0">
                            <children>
                                <Label style="-fx-font-size: 20px; -fx-font-weight: bold;" text="Catálogo de la Ludoteca" />
                                <Region HBox.hgrow="ALWAYS" />
                                <TextField fx:id="txtBuscarEjemplar" prefWidth="200.0" promptText="Buscar ejemplar..." />
                                <Button fx:id="btnNuevoEjemplar" mnemonicParsing="false" onAction="#abrirFormularioNuevo" style="-fx-background-color: #2196F3; -fx-text-fill: white; -fx-font-weight: bold;" text="+ Nuevo Ejemplar" />
                            </children>
                        </HBox>
                        
                        <ScrollPane fitToWidth="true" VBox.vgrow="ALWAYS" style="-fx-background-color: transparent;">
                            <content>
                                <TilePane fx:id="gridEjemplares" hgap="15.0" vgap="15.0" prefColumns="3" style="-fx-padding: 10;" />
                            </content>
                        </ScrollPane>
                    </children>
                </VBox>

                <StackPane fx:id="stackPanelDerecho" style="-fx-background-color: white;">
                    <padding>
                        <Insets bottom="15.0" left="15.0" right="15.0" top="15.0" />
                    </padding>
                    <children>
                        
                        <TabPane fx:id="tabPaneDetalles" tabClosingPolicy="UNAVAILABLE">
                            <tabs>
                                <Tab text="Ficha del Juego">
                                    <content>
                                        <VBox spacing="15.0" style="-fx-padding: 15;">
                                            <HBox spacing="15.0">
                                                <ImageView fx:id="imgDetalle" fitHeight="200.0" fitWidth="150.0" preserveRatio="true" />
                                                <VBox spacing="5.0" HBox.hgrow="ALWAYS">
                                                    <Label fx:id="lblDetalleTitulo" style="-fx-font-size: 22px; -fx-font-weight: bold;" wrapText="true" />
                                                    <Label fx:id="lblDetalleAno" style="-fx-font-size: 14px; -fx-text-fill: gray;" />
                                                    
                                                    <GridPane hgap="10.0" vgap="8.0" style="-fx-padding: 10 0 0 0;">
                                                        <columnConstraints>
                                                            <ColumnConstraints hgrow="NEVER" minWidth="120.0" />
                                                            <ColumnConstraints hgrow="ALWAYS" />
                                                        </columnConstraints>
                                                        
                                                        <Label text="Autor:" GridPane.columnIndex="0" GridPane.rowIndex="0" style="-fx-font-weight: bold;" />
                                                        <Label fx:id="lblDetalleAutor" GridPane.columnIndex="1" GridPane.rowIndex="0" wrapText="true" />

                                                        <Label text="Jugadores:" GridPane.columnIndex="0" GridPane.rowIndex="1" style="-fx-font-weight: bold;" />
                                                        <Label fx:id="lblDetalleJugadores" GridPane.columnIndex="1" GridPane.rowIndex="1" />
                                                        
                                                        <Label text="Recomendado:" GridPane.columnIndex="0" GridPane.rowIndex="2" style="-fx-font-weight: bold;" />
                                                        <Label fx:id="lblDetalleJugRecomendados" GridPane.columnIndex="1" GridPane.rowIndex="2" />
                                                        
                                                        <Label text="Duración:" GridPane.columnIndex="0" GridPane.rowIndex="3" style="-fx-font-weight: bold;" />
                                                        <Label fx:id="lblDetalleDuracion" GridPane.columnIndex="1" GridPane.rowIndex="3" />
                                                        
                                                        <Label text="Categoría:" GridPane.columnIndex="0" GridPane.rowIndex="4" style="-fx-font-weight: bold;" />
                                                        <Label fx:id="lblDetalleCategorias" GridPane.columnIndex="1" GridPane.rowIndex="4" wrapText="true" />
                                                        
                                                        <Label text="Mecánicas:" GridPane.columnIndex="0" GridPane.rowIndex="5" style="-fx-font-weight: bold;" />
                                                        <Label fx:id="lblDetalleMecanicas" GridPane.columnIndex="1" GridPane.rowIndex="5" wrapText="true" />
                                                        
                                                        <Label text="Dureza / Peso:" GridPane.columnIndex="0" GridPane.rowIndex="6" style="-fx-font-weight: bold;" />
                                                        <Label fx:id="lblDetalleDureza" GridPane.columnIndex="1" GridPane.rowIndex="6" />

                                                        <Label text="Puntuación BGG:" GridPane.columnIndex="0" GridPane.rowIndex="7" style="-fx-font-weight: bold;" />
                                                        <Label fx:id="lblDetallePuntuacion" GridPane.columnIndex="1" GridPane.rowIndex="7" />
                                                    </GridPane>
                                                </VBox>
                                            </HBox>
                                            <Label style="-fx-font-weight: bold;" text="Descripción:" />
                                            <TextArea fx:id="txtDetalleDescripcion" editable="false" wrapText="true" VBox.vgrow="ALWAYS" />
                                        </VBox>
                                    </content>
                                </Tab>
                                
                                <Tab text="Datos Físicos">
                                    <content>
                                        <VBox spacing="15.0" style="-fx-padding: 15;">
                                            <HBox alignment="CENTER_LEFT" spacing="10.0">
                                                <Label style="-fx-font-size: 18px; -fx-font-weight: bold;" text="Información del Ejemplar" />
                                                <Region HBox.hgrow="ALWAYS" />
                                                <Label fx:id="lblDetalleEstado" style="-fx-font-size: 14px; -fx-font-weight: bold; -fx-padding: 3 8; -fx-background-radius: 3; -fx-text-fill: white;" />
                                            </HBox>
                                            
                                            <GridPane hgap="10.0" vgap="15.0">
                                                <columnConstraints>
                                                    <ColumnConstraints hgrow="NEVER" minWidth="120.0" />
                                                    <ColumnConstraints hgrow="ALWAYS" />
                                                </columnConstraints>
                                                <Label text="Código Local:" GridPane.columnIndex="0" GridPane.rowIndex="0" style="-fx-font-weight: bold;" />
                                                <Label fx:id="lblDetalleCodigo" GridPane.columnIndex="1" GridPane.rowIndex="0" />
                                                <Label text="Balda:" GridPane.columnIndex="0" GridPane.rowIndex="1" style="-fx-font-weight: bold;" />
                                                <Label fx:id="lblDetalleBalda" GridPane.columnIndex="1" GridPane.rowIndex="1" />
                                                <Label text="Adquisición:" GridPane.columnIndex="0" GridPane.rowIndex="2" style="-fx-font-weight: bold;" />
                                                <Label fx:id="lblDetalleAdquisicion" GridPane.columnIndex="1" GridPane.rowIndex="2" />
                                                <Label text="En Venta:" GridPane.columnIndex="0" GridPane.rowIndex="3" style="-fx-font-weight: bold;" />
                                                <Label fx:id="lblDetalleEnVenta" GridPane.columnIndex="1" GridPane.rowIndex="3" />
                                                <Label text="Prestado A:" GridPane.columnIndex="0" GridPane.rowIndex="4" style="-fx-font-weight: bold;" />
                                                <Label fx:id="lblDetallePrestadoA" text="Nadie" GridPane.columnIndex="1" GridPane.rowIndex="4" />
                                            </GridPane>
                                            <Label style="-fx-font-weight: bold;" text="Anotaciones:" />
                                            <TextArea fx:id="txtDetalleAnotaciones" editable="false" wrapText="true" prefHeight="80.0" />
                                        </VBox>
                                    </content>
                                </Tab>
                            </tabs>
                        </TabPane>

                        <ScrollPane fx:id="panelRegistro" visible="false" managed="false" fitToWidth="true" style="-fx-background-color: transparent;">
                            <content>
                                <VBox spacing="15.0" style="-fx-background-color: white; -fx-padding: 20;">
                                    <Label style="-fx-font-size: 20px; -fx-font-weight: bold;" text="Registrar Nuevo Ejemplar" />
                                    
                                    <VBox spacing="5.0" style="-fx-background-color: #f9f9f9; -fx-padding: 10; -fx-border-color: #e0e0e0; -fx-border-radius: 5;">
                                        <Label text="1. Busca el Juego (Base de Datos Teórica):" style="-fx-font-weight: bold;" />
                                        <HBox spacing="10.0">
                                            <TextField fx:id="txtBuscarRefLocal" HBox.hgrow="ALWAYS" promptText="Escribe el nombre..." />
                                        </HBox>
                                        <ComboBox fx:id="cmbJuegoReferencia" prefWidth="Infinity" promptText="Selecciona un resultado..." />
                                    </VBox>

                                    <Label text="Código Local (ej: CAT-001):" />
                                    <TextField fx:id="txtNuevoCodigo" />
                                    <Label text="Balda:" />
                                    <TextField fx:id="txtNuevaBalda" />
                                    <Label text="Fecha de Adquisición:" />
                                    <DatePicker fx:id="dpFechaAdquisicion" prefWidth="Infinity" />
                                    
                                    <HBox spacing="20.0">
                                        <VBox spacing="5.0" HBox.hgrow="ALWAYS">
                                            <Label text="Estado Inicial:" />
                                            <ComboBox fx:id="cmbNuevoEstado" prefWidth="Infinity" />
                                        </VBox>
                                        <VBox spacing="5.0" HBox.hgrow="ALWAYS">
                                            <Label text="¿En Venta (Mercadillo)?" />
                                            <ComboBox fx:id="cmbEnVenta" prefWidth="Infinity" />
                                        </VBox>
                                    </HBox>
                                    
                                    <Label text="Anotaciones (opcional):" />
                                    <TextArea fx:id="txtNuevasAnotaciones" prefHeight="60.0" />
                                    
                                    <Region VBox.vgrow="ALWAYS" />
                                    <HBox spacing="10.0" alignment="CENTER_RIGHT">
                                        <Button mnemonicParsing="false" onAction="#cancelarRegistro" style="-fx-background-color: #9E9E9E; -fx-text-fill: white;" text="Cancelar" />
                                        <Button fx:id="btnGuardarEjemplar" mnemonicParsing="false" onAction="#guardarEjemplar" style="-fx-background-color: #4CAF50; -fx-text-fill: white; -fx-font-weight: bold;" text="Guardar Ejemplar" />
                                    </HBox>
                                </VBox>
                            </content>
                        </ScrollPane>

                    </children>
                </StackPane>
            </items>
        </SplitPane>
    </children>
</AnchorPane>